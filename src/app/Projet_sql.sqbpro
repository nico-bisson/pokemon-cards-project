olumns/><plot_y_axes/><global_filter/></table><table schema="main" name="series" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="4" mode="0"/></sort><column_widths><column index="1" value="46"/><column index="2" value="179"/><column index="3" value="156"/><column index="4" value="95"/><column index="5" value="72"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="series_classification" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="46"/><column index="2" value="179"/><column index="3" value="72"/><column index="4" value="95"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sets" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="0"/></sort><column_widths><column index="1" value="93"/><column index="2" value="241"/><column index="3" value="60"/><column index="4" value="71"/><column index="5" value="46"/><column index="6" value="85"/><column index="7" value="300"/><column index="8" value="300"/><column index="9" value="156"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 2">select COUNT(*), p.name from cards as c
inner join pokemons as p
on c.dex_id_1 = p.dex_id
where category = 'Pokemon'
and dex_id_2 is NULL
group by dex_id_1
order by COUNT(*) DESC

</sql><sql name="SQL 3">WITH pokemon_counts AS (
    SELECT 
        g.id        AS generation_id,
        g.name      AS generation,
        p.name      AS pokemon,
        COUNT(*)    AS card_count
    FROM cards c
    JOIN pokemons p 
        ON p.dex_id = c.dex_id_1
    JOIN generations g 
        ON c.dex_id_1 BETWEEN g.dex_start AND g.dex_end
    WHERE c.category = 'Pokemon'
      AND c.dex_id_2 IS NULL
    GROUP BY g.id, g.name, p.name
)
SELECT *
FROM (
    SELECT *,
           RANK() OVER (
               PARTITION BY generation_id
               ORDER BY card_count DESC
           ) AS rnk
    FROM pokemon_counts
) t
WHERE rnk &lt;= 1
ORDER BY generation_id, rnk, pokemon;</sql><sql name="SQL 4">WITH pokemon_counts AS (
    SELECT 
        g.id        AS generation_id,
        g.name      AS generation,
        p.name      AS pokemon,
        COUNT(*)    AS card_count
    FROM cards c
    JOIN pokemons p 
        ON p.dex_id = c.dex_id_1
    JOIN generations g 
        ON c.dex_id_1 BETWEEN g.dex_start AND g.dex_end
    WHERE c.category = 'Pokemon'
      AND c.dex_id_2 IS NULL
    GROUP BY g.id, g.name, p.name
)
SELECT *
FROM (
    SELECT *,
           RANK() OVER (
               PARTITION BY generation_id
               ORDER BY card_count ASC
           ) AS rnk
    FROM pokemon_counts
) t
WHERE rnk &lt;= 10
ORDER BY generation_id, rnk, pokemon;</sql><sql name="SQL 5">select hp, name from cards
order by hp DESC
</sql><sql name="SQL 6">select COUNT(*), illustrator from cards
group by illustrator
order by COUNT(*) DESC;
</sql><sql name="SQL 7">WITH counts AS (
    SELECT 
        s.name AS series_name,
        c.illustrator,
        COUNT(*) AS card_count
    FROM cards c
    INNER JOIN sets se
        ON c.set_id = se.id
    INNER JOIN series s
        ON se.series_id = s.id
    GROUP BY s.name, c.illustrator
),
ranked AS (
    SELECT *,
           RANK() OVER (
               PARTITION BY series_name
               ORDER BY card_count DESC
           ) AS rn
    FROM counts
)
SELECT 
    series_name,
    illustrator,
    card_count
FROM ranked
WHERE rn &lt;= 5
ORDER BY series_name, card_count DESC;</sql><sql name="SQL 9">SELECT 
    s.name AS series_name,

    COUNT(*) AS total_cards,

    SUM(CASE 
            WHEN c.illustrator = '5ban Graphics' 
            THEN 1 
            ELSE 0 
        END) AS fiveban_cards,

    ROUND(
        100.0 * SUM(CASE 
                        WHEN c.illustrator = '5ban Graphics' 
                        THEN 1 
                        ELSE 0 
                    END) 
        / COUNT(*),
        2
    ) AS fiveban_percentage

FROM cards c
INNER JOIN sets se
    ON c.set_id = se.id
INNER JOIN series s
    ON se.series_id = s.id

GROUP BY s.name
ORDER BY fiveban_percentage DESC;</sql><sql name="SQL 10">SELECT 
    s.name AS series_name,

    COUNT(*) AS total_cards,

    SUM(CASE 
            WHEN c.illustrator = 'Ken Sugimori' 
            THEN 1 
            ELSE 0 
        END) AS fiveban_cards,

    ROUND(
        100.0 * SUM(CASE 
                        WHEN c.illustrator = 'Ken Sugimori' 
                        THEN 1 
                        ELSE 0 
                    END) 
        / COUNT(*),
        2
    ) AS fiveban_percentage

FROM cards c
INNER JOIN sets se
    ON c.set_id = se.id
INNER JOIN series s
    ON se.series_id = s.id

GROUP BY s.name
ORDER BY fiveban_percentage DESC;</sql><sql name="SQL 11">SELECT 
    s.name AS series_name,
    MIN(se.release_date) AS first_release_date
FROM sets se
INNER JOIN series s
    ON se.series_id = s.id
GROUP BY s.name
ORDER BY first_release_date;</sql><sql name="SQL 12">SELECT 
    s.name AS series_name,

    MIN(se.release_date) AS first_release_date,

    ROUND(
        100.0 * SUM(CASE 
                        WHEN c.illustrator = '5ban Graphics' 
                        THEN 1 ELSE 0 
                    END) 
        / COUNT(*),
        2
    ) AS fiveban_percentage,

    ROUND(
        100.0 * SUM(CASE 
                        WHEN c.illustrator = 'Ken Sugimori' 
                        THEN 1 ELSE 0 
                    END) 
        / COUNT(*),
        2
    ) AS ken_sugimori_percentage

FROM cards c
JOIN sets se ON c.set_id = se.id
JOIN series s ON se.series_id = s.id

GROUP BY s.name
ORDER BY first_release_date;</sql><sql name="SQL 13">select s.name, COUNT(c.id), MIN(se.release_date) AS first_release_date
FROM cards c
JOIN sets se ON c.set_id = se.id
JOIN series s ON se.series_id = s.id
GROUP BY s.name
ORDER BY first_release_date;</sql><sql name="SQL 14">select COUNT(*), c.name c, c.dex_id_1, se.name as serie_name, se.release_date, s.name, s.id as set_name from sets se
JOIN series s ON se.series_id = s.id
JOIN cards c ON c.set_id = se.id
where s.id = 'mc'
group by dex_id_1
order by count(*) DESC
</sql><sql name="SQL 15">select se.total_cards, se.name as serie_name, se.release_date, s.name, s.id as set_name from sets se
JOIN series s ON se.series_id = s.id
where s.id = 'mc'
order by release_date
</sql><sql name="SQL 16">select name,
total_cards - official as secrets,
release_date
from sets
ORDER BY release_date;</sql><sql name="SQL 17">select COUNT(*), rarity from cards
group by rarity
order by count(*) DESC</sql><sql name="SQL 16*">SELECT 
        p.dex_id,
        p.name,
        COUNT(DISTINCT c.id) AS card_count,
        se.series_type
    FROM pokemons p
    LEFT JOIN cards c ON c.dex_id_1 = p.dex_id OR c.dex_id_2 = p.dex_id OR c.dex_id_3 = p.dex_id OR c.dex_id_4 = p.dex_id OR c.dex_id_5 = p.dex_id
    INNER JOIN sets s ON c.set_id = s.id
    INNER JOIN series se ON s.series_id = se.id
    WHERE p.name IS NOT NULL
    GROUP BY p.dex_id, p.name
    ORDER BY p.dex_id</sql><current_tab id="15"/></tab_sql></sqlb_project>
